# CertPrep environment configuration.
# Copy to `.env` (or `.env.local`) and adjust as needed. All values have sane
# defaults in src/server/config.ts, so this file is optional for local dev.

# Port the Next.js server binds (dev + start).
PORT=3000

# Path to the SQLite database file (created + migrated on boot).
DB_PATH=./data/certprep.db

# Root directory that the catalogue scans for question-set JSON files.
EXAMS_ROOT=./Exams

# The navigation tree (cascading-dropdown source of truth).
EXAM_PATHS_FILE=./exam-paths.json

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info
